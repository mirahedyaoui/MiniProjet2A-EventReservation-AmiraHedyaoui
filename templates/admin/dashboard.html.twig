{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<h1>Dashboard Admin</h1>
<a href="{{ path('admin_event_create') }}">Créer un nouvel événement</a>
<table>
    <thead>
        <tr>
            <th>Titre</th>
            <th>Date</th>
            <th>Lieu</th>
            <th>Places</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for event in events %}
        <tr>
            <td>{{ event.title }}</td>
            <td>{{ event.date|date('d/m/Y') }}</td>
            <td>{{ event.location }}</td>
            <td>{{ event.seats }}</td>
            <td>
                <a href="{{ path('admin_event_edit', {'id': event.id}) }}">Modifier</a>
                <a href="{{ path('admin_reservations', {'id': event.id}) }}">Réservations</a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}